{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Rekber+ platform",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "name": {
          "type": "string",
          "description": "The user's full name"
        },
        "balance": {
          "type": "number",
          "description": "The user's internal balance"
        },
        "pin": {
          "type": "string",
          "description": "6-digit security PIN for transactions"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Whether the user has enabled notifications"
        },
        "phone": {
          "type": "string",
          "description": "User's phone number"
        },
        "bankName": {
          "type": "string",
          "description": "User's bank name for withdrawals"
        },
        "bankAccount": {
          "type": "string",
          "description": "User's bank account number"
        },
        "bankAccountName": {
          "type": "string",
          "description": "User's bank account holder name"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "email", "name", "balance", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "An escrow transaction between a buyer and a seller",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the transaction"
        },
        "description": {
          "type": "string",
          "description": "Description of the goods or services"
        },
        "price": {
          "type": "number",
          "description": "Price of the goods or services"
        },
        "fee": {
          "type": "number",
          "description": "Platform fee (2%)"
        },
        "total": {
          "type": "number",
          "description": "Total amount to be paid (price + fee)"
        },
        "creatorId": {
          "type": "string",
          "description": "UID of the user who created the transaction"
        },
        "creatorRole": {
          "type": "string",
          "enum": ["buyer", "seller"],
          "description": "Role of the creator"
        },
        "buyerId": {
          "type": "string",
          "description": "UID of the buyer"
        },
        "sellerId": {
          "type": "string",
          "description": "UID of the seller"
        },
        "status": {
          "type": "string",
          "enum": [
            "waiting_payment",
            "funds_held",
            "processing",
            "shipped",
            "completed",
            "cancelled",
            "disputed"
          ],
          "description": "Current status of the transaction"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the transaction was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the transaction was last updated"
        },
        "isClaimed": {
          "type": "boolean",
          "description": "Whether the seller has claimed the funds after completion"
        }
      },
      "required": [
        "title",
        "description",
        "price",
        "fee",
        "total",
        "creatorId",
        "creatorRole",
        "status",
        "createdAt",
        "updatedAt"
      ]
    },
    "TopUp": {
      "title": "TopUp",
      "description": "Manual top-up request with unique code",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user requesting the top-up"
        },
        "nominal": {
          "type": "number",
          "description": "The base amount requested"
        },
        "uniqueCode": {
          "type": "number",
          "description": "The unique 3-digit code"
        },
        "amount": {
          "type": "number",
          "description": "The total amount to transfer (nominal + uniqueCode)"
        },
        "status": {
          "type": "string",
          "enum": ["PENDING", "SUCCESS", "REJECTED", "EXPIRED"],
          "description": "The status of the top-up"
        },
        "adminId": {
          "type": "string",
          "description": "The admin who processed the top-up"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the top-up was created"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the pending top-up expires"
        },
        "processedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the top-up was processed"
        }
      },
      "required": ["userId", "nominal", "uniqueCode", "amount", "status", "createdAt", "expiresAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "User withdrawal request",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user requesting the withdrawal"
        },
        "userName": {
          "type": "string"
        },
        "amount": {
          "type": "number",
          "description": "The amount requested"
        },
        "status": {
          "type": "string",
          "enum": ["PENDING", "PROCESSING", "SUCCESS", "FAILED"],
          "description": "The status of the withdrawal"
        },
        "bankName": {
          "type": "string"
        },
        "bankAccount": {
          "type": "string"
        },
        "bankAccountName": {
          "type": "string"
        },
        "adminId": {
          "type": "string"
        },
        "rejectReason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "processedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "userName", "amount", "status", "bankName", "bankAccount", "bankAccountName", "createdAt"]
    },
    "Ledger": {
      "title": "Ledger",
      "description": "Financial ledger entry",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user associated with the ledger entry"
        },
        "type": {
          "type": "string",
          "enum": ["CREDIT", "DEBIT"],
          "description": "The type of transaction"
        },
        "amount": {
          "type": "number",
          "description": "The transaction amount"
        },
        "reference": {
          "type": "string",
          "description": "The reference ID (e.g., topup_id or transaction_id)"
        },
        "description": {
          "type": "string",
          "description": "Description of the ledger entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the ledger entry was created"
        }
      },
      "required": ["userId", "type", "amount", "reference", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles"
    },
    "/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Stores escrow transactions"
    },
    "/topups/{topupId}": {
      "schema": {
        "$ref": "#/entities/TopUp"
      },
      "description": "Stores manual top-up requests"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": {
        "$ref": "#/entities/Withdrawal"
      },
      "description": "Stores user withdrawal requests"
    },
    "/ledgers/{ledgerId}": {
      "schema": {
        "$ref": "#/entities/Ledger"
      },
      "description": "Stores financial ledger entries"
    }
  }
}
